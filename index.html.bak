<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ujjawal Gandhi — Flutter Developer</title>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg:       #F5F5DC;
            --bg2:      #EDEBD0;
            --card:     #FAFAF2;
            --red:      #E35336;
            --sand:     #F4A460;
            --brown:    #A0522D;
            --ink:      #1C0A04;
            --ink2:     #6b3a1f;
            --ink3:     #c4a882;
            --border:   rgba(160, 82, 45, 0.14);
        }

        html { scroll-behavior: smooth; }

        body {
            background: var(--bg);
            color: var(--ink);
            font-family: 'DM Sans', sans-serif;
            overflow-x: hidden;
            cursor: none;
        }

        /* ── CURSOR ── */
        #cur {
            width: 8px; height: 8px;
            background: var(--red);
            border-radius: 50%;
            position: fixed; pointer-events: none; z-index: 9999;
            transform: translate(-50%,-50%);
            transition: width .15s, height .15s, background .2s;
        }
        #cur-ring {
            width: 32px; height: 32px;
            border: 1.5px solid rgba(227,83,54,.4);
            border-radius: 50%;
            position: fixed; pointer-events: none; z-index: 9998;
            transform: translate(-50%,-50%);
            transition: left .1s ease, top .1s ease, width .25s, height .25s;
        }
        body:has(a:hover) #cur, body:has(button:hover) #cur { width: 16px; height: 16px; background: var(--brown); }
        body:has(a:hover) #cur-ring { width: 50px; height: 50px; border-color: rgba(160,82,45,.35); }

        /* ── PROGRESS BAR ── */
        #prog {
            position: fixed; top: 0; left: 0; height: 3px;
            background: linear-gradient(90deg, var(--red), var(--sand));
            z-index: 200; width: 0%; transition: width .1s;
        }

        /* ══════════════════════════
           NAV
        ══════════════════════════ */
        nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            padding: 1.1rem 3rem;
            display: flex; align-items: center; justify-content: space-between;
            background: rgba(245,245,220,.9);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
        }
        .logo {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900; font-size: 1.6rem;
            letter-spacing: .05em; color: var(--ink);
            text-decoration: none; cursor: none;
        }
        .logo span { color: var(--red); }
        .nav-links { display: flex; gap: 2rem; list-style: none; }
        .nav-links a {
            color: var(--ink2); text-decoration: none;
            font-size: .78rem; font-weight: 600;
            letter-spacing: .1em; text-transform: uppercase;
            transition: color .2s; cursor: none;
        }
        .nav-links a:hover { color: var(--red); }
        .nav-hire {
            padding: .5rem 1.4rem;
            background: var(--ink);
            color: var(--bg);
            font-size: .75rem; font-weight: 700;
            letter-spacing: .08em; text-transform: uppercase;
            border: none; border-radius: 3px;
            text-decoration: none; cursor: none;
            transition: background .2s, transform .15s;
        }
        .nav-hire:hover { background: var(--red); transform: translateY(-1px); }

        /* ══════════════════════════
           HERO — EDITORIAL SPLIT
        ══════════════════════════ */
        #hero {
            min-height: 92vh;
            display: grid;
            grid-template-columns: 1fr auto;
            grid-template-rows: 1fr auto;
            position: relative;
            padding-top: 0;
        }

        .hero-left {
            background: var(--bg);
            padding: 6.5rem 3rem 2.5rem;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            position: relative;
            overflow: hidden;
        }

        /* big decorative circle */
        .hero-left::before {
            content: '';
            position: absolute;
            right: -80px; top: 50%;
            transform: translateY(-50%);
            width: 280px; height: 280px;
            border-radius: 50%;
            background: var(--sand);
            opacity: .18;
            pointer-events: none;
        }

        .hero-eyebrow {
            display: inline-flex; align-items: center; gap: .6rem;
            font-size: .72rem; font-weight: 700;
            letter-spacing: .18em; text-transform: uppercase;
            color: var(--red);
            margin-bottom: 1.5rem;
            animation: fadeUp .7s .1s both;
        }
        .hero-eyebrow::before {
            content: ''; width: 24px; height: 2px; background: var(--red);
        }

        .hero-name {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: clamp(5.5rem, 13vw, 12rem);
            line-height: .88;
            letter-spacing: -.01em;
            color: var(--ink);
            animation: fadeUp .8s .2s both;
        }
        .hero-name .stroke {
            -webkit-text-stroke: 2px var(--ink);
            color: transparent;
        }
        .hero-name .red { color: var(--red); }

        .hero-mid {
            display: flex;
            flex-direction: column;
            gap: 1.2rem;
            margin-top: 2rem;
            animation: fadeUp .8s .4s both;
        }

        .hero-desc {
            max-width: 340px;
            font-size: .92rem;
            line-height: 1.7;
            color: var(--ink2);
            font-weight: 400;
        }
        .hero-desc strong { color: var(--ink); font-weight: 700; }

        .platforms {
            display: flex; gap: .5rem; flex-wrap: wrap;
        }
        .plat {
            display: flex; align-items: center; gap: .35rem;
            padding: .35rem .9rem;
            border: 1.5px solid var(--border);
            border-radius: 3px;
            font-size: .72rem; font-weight: 600;
            letter-spacing: .05em;
            color: var(--ink2);
            background: var(--card);
            transition: border-color .2s, color .2s, background .2s;
        }
        .plat:hover { border-color: var(--red); color: var(--red); background: rgba(227,83,54,.04); }

        .hero-cta {
            display: flex; gap: .75rem; flex-wrap: wrap;
            margin-top: 2.5rem;
            animation: fadeUp .8s .55s both;
        }
        .btn-p {
            padding: .85rem 2.2rem;
            background: var(--ink);
            color: var(--bg);
            font-family: 'DM Sans', sans-serif;
            font-size: .82rem; font-weight: 700;
            letter-spacing: .07em; text-transform: uppercase;
            border: none; border-radius: 3px;
            text-decoration: none; cursor: none;
            transition: background .2s, transform .15s;
        }
        .btn-p:hover { background: var(--red); transform: translateY(-2px); }
        .btn-s {
            padding: .85rem 2.2rem;
            background: transparent;
            color: var(--ink);
            font-family: 'DM Sans', sans-serif;
            font-size: .82rem; font-weight: 600;
            letter-spacing: .07em; text-transform: uppercase;
            border: 1.5px solid var(--ink);
            border-radius: 3px;
            text-decoration: none; cursor: none;
            transition: border-color .2s, color .2s;
        }
        .btn-s:hover { border-color: var(--red); color: var(--red); }

        /* HERO BOTTOM META BAR */
        .hero-bottom {
            border-top: 1px solid var(--border);
            display: flex; justify-content: space-between; align-items: center;
            padding: 1.25rem 3rem 1.25rem;
            font-size: .7rem; font-weight: 700;
            letter-spacing: .14em; text-transform: uppercase;
            color: var(--ink2);
            animation: fadeUp .7s .7s both;
        }
        .hero-bottom span { display: flex; align-items: center; gap: .5rem; }
        .live-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: var(--red);
            box-shadow: 0 0 8px var(--red);
            animation: blink 2s infinite;
        }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

        /* RIGHT PANEL — color block */
        .hero-right {
            width: 34vw;
            background: var(--sand);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-end;
            padding: 2rem;
        }
        .hero-right::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(60% 60% at 30% 30%, rgba(227,83,54,.25), transparent),
                radial-gradient(50% 50% at 80% 80%, rgba(160,82,45,.3), transparent);
        }
        .hero-right-inner {
            position: relative; z-index: 1;
            width: 100%; text-align: center;
        }
        .flutter-logo-wrap {
            margin-bottom: 1.5rem;
        }
        .flutter-logo-svg {
            width: 100px; height: 100px;
            filter: drop-shadow(0 8px 32px rgba(160,82,45,.35));
        }
        .hero-right-tag {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            font-size: clamp(1.5rem, 3vw, 2.4rem);
            letter-spacing: .04em;
            color: var(--ink);
            line-height: 1.1;
        }
        .hero-right-sub {
            font-size: .75rem; font-weight: 500;
            color: var(--ink2); margin-top: .5rem;
            letter-spacing: .06em;
        }
        /* big number watermark in panel */
        .hero-panel-num {
            position: absolute;
            top: 1rem; right: 1.5rem;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: 7rem;
            color: rgba(28,10,4,.08);
            line-height: 1;
            pointer-events: none;
        }

        /* ══════════════════════════
           MARQUEE
        ══════════════════════════ */
        .mq-wrap {
            overflow: hidden;
            padding: .9rem 0;
            background: var(--ink);
            position: relative; z-index: 2;
        }
        .mq-track { display: flex; width: max-content; animation: marquee 22s linear infinite; }
        .mq-item {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: .95rem; font-weight: 700;
            letter-spacing: .18em; text-transform: uppercase;
            color: var(--bg2);
            padding: 0 2rem;
            display: flex; align-items: center; gap: 2rem;
        }
        .mq-item .dot { color: var(--red); font-size: .5rem; }
        @keyframes marquee { to { transform: translateX(-50%); } }

        /* ══════════════════════════
           SECTIONS
        ══════════════════════════ */
        .sec {
            max-width: 1100px; margin: 0 auto;
            padding: 4.5rem 3rem;
            position: relative; z-index: 2;
        }

        .sec-eyebrow {
            display: inline-flex; align-items: center; gap: .6rem;
            font-size: .7rem; font-weight: 700;
            letter-spacing: .18em; text-transform: uppercase;
            color: var(--red); margin-bottom: .6rem;
        }
        .sec-eyebrow::before { content: ''; width: 20px; height: 2px; background: var(--red); }

        .sec-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: clamp(2.8rem, 6vw, 5rem);
            letter-spacing: .02em;
            line-height: .92;
            margin-bottom: 3.5rem;
            color: var(--ink);
        }
        .sec-title .stroke {
            -webkit-text-stroke: 2px var(--ink);
            color: transparent;
        }
        .sec-title .red { color: var(--red); }

        /* ══════════════════════════
           SKILLS
        ══════════════════════════ */
        .sk-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
        }
        .sk-tile {
            background: var(--card);
            padding: 1.75rem 1rem;
            text-align: center;
            transition: background .2s;
            cursor: default;
        }
        .sk-tile:hover { background: var(--bg2); }
        .sk-icon { font-size: 1.8rem; margin-bottom: .5rem; }
        .sk-name { font-size: .78rem; font-weight: 700; color: var(--ink2); letter-spacing: .04em; }

        /* ══════════════════════════
           EXPERIENCE
        ══════════════════════════ */
        .exp-card {
            border: 1px solid var(--border);
            border-radius: 10px;
            background: var(--card);
            margin-bottom: 1rem;
            overflow: hidden;
            position: relative;
            transition: border-color .25s, transform .25s, box-shadow .25s;
        }
        .exp-card::before {
            content: '';
            position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
            background: linear-gradient(180deg, var(--red), var(--sand));
            transform: scaleY(0); transform-origin: top;
            transition: transform .4s cubic-bezier(.16,1,.3,1);
        }
        .exp-card:hover { border-color: rgba(227,83,54,.25); transform: translateX(6px); box-shadow: -6px 0 30px rgba(227,83,54,.07); }
        .exp-card:hover::before { transform: scaleY(1); }
        .exp-inner { padding: 2rem 2.25rem; }
        .exp-top { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: .5rem; margin-bottom: .3rem; }
        .exp-role {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800; font-size: 1.6rem;
            letter-spacing: .03em; color: var(--ink);
        }
        .exp-period {
            font-size: .72rem; font-weight: 700;
            letter-spacing: .08em; text-transform: uppercase;
            color: var(--red);
            background: rgba(227,83,54,.08);
            border: 1px solid rgba(227,83,54,.2);
            padding: .25rem .75rem; border-radius: 3px;
        }
        .exp-co { font-size: .85rem; color: var(--ink2); margin-bottom: 1rem; font-weight: 500; }
        .exp-pts { list-style: none; }
        .exp-pts li {
            font-size: .85rem; color: var(--ink2); line-height: 1.65;
            padding: .35rem 0 .35rem 1.3rem;
            position: relative;
            border-top: 1px solid var(--border);
        }
        .exp-pts li:first-child { border-top: none; }
        .exp-pts li::before {
            content: '';
            position: absolute; left: 0; top: 50%; transform: translateY(-50%);
            width: 5px; height: 5px; border-radius: 50%;
            background: var(--red);
        }

        /* ══════════════════════════
           PROJECTS — EDITORIAL CARDS
        ══════════════════════════ */
        .proj-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
        }
        .proj-card {
            background: var(--card);
            padding: 2rem;
            position: relative;
            overflow: hidden;
            transition: background .2s;
            cursor: default;
        }
        .proj-card:hover { background: var(--bg2); }
        .proj-card:hover .proj-num { color: var(--red); opacity: .15; }
        .proj-num {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: 5rem;
            color: var(--ink); opacity: .06;
            position: absolute; top: .5rem; right: 1rem;
            line-height: 1;
            transition: color .2s, opacity .2s;
        }
        .proj-ico { font-size: 2rem; margin-bottom: 1rem; display: block; }
        .proj-name {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800; font-size: 1.5rem;
            letter-spacing: .03em; margin-bottom: .5rem;
            color: var(--ink);
        }
        .proj-desc { font-size: .83rem; color: var(--ink2); line-height: 1.7; margin-bottom: 1.25rem; }
        .ptags { display: flex; flex-wrap: wrap; gap: .35rem; }
        .pt {
            font-size: .65rem; font-weight: 700;
            letter-spacing: .07em; text-transform: uppercase;
            padding: .2rem .65rem; border-radius: 2px;
        }
        .pt-r { background: rgba(227,83,54,.1); color: var(--red); border: 1px solid rgba(227,83,54,.2); }
        .pt-s { background: rgba(244,164,96,.1); color: #c07828; border: 1px solid rgba(244,164,96,.25); }
        .pt-b { background: rgba(160,82,45,.08); color: var(--brown); border: 1px solid rgba(160,82,45,.18); }
        .pt-k { background: rgba(28,10,4,.05); color: var(--ink2); border: 1px solid rgba(28,10,4,.12); }

        /* ══════════════════════════
           CONTACT
        ══════════════════════════ */
        #contact { background: var(--ink); position: relative; z-index: 2; }
        .ct-inner {
            max-width: 1100px; margin: 0 auto;
            padding: 6rem 3rem;
        }
        .ct-eyebrow {
            display: inline-flex; align-items: center; gap: .6rem;
            font-size: .7rem; font-weight: 700;
            letter-spacing: .18em; text-transform: uppercase;
            color: var(--sand); margin-bottom: .6rem;
        }
        .ct-eyebrow::before { content: ''; width: 20px; height: 2px; background: var(--sand); }
        .ct-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: clamp(3rem, 7vw, 6.5rem);
            line-height: .88; letter-spacing: .02em;
            color: var(--bg);
            margin-bottom: 1rem;
        }
        .ct-title .red { color: var(--red); }
        .ct-sub {
            color: var(--ink3);
            font-size: .95rem; font-weight: 400;
            max-width: 400px; line-height: 1.7;
            margin-bottom: 3rem;
        }
        .ct-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
            gap: .75rem;
        }
        .ct-btn {
            display: flex; align-items: center; gap: .6rem;
            padding: 1rem 1.4rem;
            border: 1px solid rgba(245,245,220,.1);
            border-radius: 6px;
            text-decoration: none;
            color: var(--ink3);
            font-size: .82rem; font-weight: 500;
            background: rgba(255,255,255,.03);
            transition: border-color .2s, color .2s, background .2s, transform .15s;
            cursor: none;
        }
        .ct-btn:hover { border-color: var(--red); color: var(--bg); background: rgba(227,83,54,.12); transform: translateY(-2px); }
        .ct-btn-primary {
            background: var(--red); border-color: var(--red); color: var(--bg); font-weight: 700;
        }
        .ct-btn-primary:hover { background: #c43f25; border-color: #c43f25; }

        /* ══════════════════════════
           FOOTER
        ══════════════════════════ */
        footer {
            background: #0e0704;
            text-align: center;
            padding: 1.5rem 3rem;
            border-top: 1px solid rgba(244,164,96,.08);
            color: rgba(196,168,130,.4);
            font-size: .7rem; letter-spacing: .1em; text-transform: uppercase;
            position: relative; z-index: 2;
        }
        footer a { color: var(--sand); text-decoration: none; cursor: none; opacity: .7; }
        footer a:hover { opacity: 1; }

        /* ══════════════════════════
           REVEAL
        ══════════════════════════ */
        .r { opacity: 0; transform: translateY(28px); transition: opacity .65s cubic-bezier(.16,1,.3,1), transform .65s cubic-bezier(.16,1,.3,1); }
        .r.on { opacity: 1; transform: translateY(0); }
        .d1 { transition-delay: .07s; } .d2 { transition-delay: .14s; } .d3 { transition-delay: .21s; }
        .d4 { transition-delay: .28s; } .d5 { transition-delay: .35s; } .d6 { transition-delay: .42s; }

        /* ══════════════════════════
           ANIMATIONS
        ══════════════════════════ */
        @keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }

        /* ══════════════════════════
           RESPONSIVE
        ══════════════════════════ */
        @media (max-width: 900px) {
            #hero { grid-template-columns: 1fr; grid-template-rows: auto auto; }
            .hero-right { width: 100%; height: 280px; justify-content: center; }
            .hero-left::before { display: none; }
        }
        @media (max-width: 700px) {
            nav { padding: 1rem 1.25rem; }
            .nav-links { display: none; }
            .hero-left { padding: 6rem 1.5rem 2rem; }
            .hero-bottom { padding: 1rem 1.5rem; flex-direction: column; gap: .5rem; align-items: flex-start; }
            .sec { padding: 4rem 1.5rem; }
            .ct-inner { padding: 4rem 1.5rem; }
        }
    </style>
</head>

<body>
    <div id="cur"></div>
    <div id="cur-ring"></div>
    <div id="prog"></div>

    <!-- NAV -->
    <nav>
        <a href="#" class="logo">UG<span>.</span></a>
        <ul class="nav-links">
            <li><a href="#skills">Skills</a></li>
            <li><a href="#work">Work</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#contact">Contact</a></li>
            <li><a href="http://www.ujjvalgandhi.online/" target="_blank" rel="noopener">Live ↗</a></li>
        </ul>
        <a href="mailto:ujjval2804@gmail.com" class="nav-hire">Hire Me</a>
    </nav>

    <!-- ═══ HERO ═══ -->
    <section id="hero">
        <div class="hero-left">
            <div>
                <div class="hero-eyebrow">Flutter Developer · Available for hire</div>
                <h1 class="hero-name">
                    UJJAWAL<br>
                    <span class="stroke">GANDHI</span>
                </h1>
                <div class="hero-mid">
                    <p class="hero-desc">
                        Building beautiful cross-platform apps for <strong>Android, iOS, Web &amp; Desktop</strong> — using Flutter &amp; Dart.
                    </p>
                    <div class="platforms">
                        <div class="plat">🤖 Android</div>
                        <div class="plat">🍎 iOS</div>
                        <div class="plat">🌐 Web</div>
                        <div class="plat">🖥️ Desktop</div>
                    </div>
                </div>
                <div class="hero-cta">
                    <a href="#projects" class="btn-p">View Projects</a>
                    <a href="#contact" class="btn-s">Let's Talk</a>
                    <a href="http://www.ujjvalgandhi.online/" target="_blank" rel="noopener" class="btn-s">Live Site ↗</a>
                </div>
            </div>
        </div>

        <!-- RIGHT COLOUR PANEL -->
        <div class="hero-right">
            <div class="hero-panel-num">01</div>
            <div class="hero-right-inner">
                <div class="flutter-logo-wrap">
                    <svg class="flutter-logo-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <polygon points="22,56 50,28 78,28 50,56" fill="#E35336" opacity="0.95"/>
                        <polygon points="22,56 50,84 78,84 50,56" fill="#1C0A04" opacity="0.75"/>
                        <polygon points="50,56 78,28 78,56" fill="#E35336" opacity="0.45"/>
                        <polygon points="50,56 78,84 78,56" fill="#A0522D" opacity="0.8"/>
                    </svg>
                </div>
